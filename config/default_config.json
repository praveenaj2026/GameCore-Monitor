{
  "app": {
    "name": "GameCore Monitor",
    "version": "0.1.0",
    "subtitle": "Gaming & System Performance Intelligence"
  },
  "monitoring": {
    "refresh_interval": 2,
    "history_length": 300
  },
  "alerts": {
    "enabled": true,
    "cpu_threshold": 90,
    "cpu_duration": 120,
    "gpu_temp_threshold": 85,
    "disk_space_threshold": 10
  },
  "sensors": {
    "cpu": {
      "enabled": true,
      "show_per_core": false
    },
    "gpu": {
      "enabled": true,
      "nvidia_only": true
    },
    "ram": {
      "enabled": true
    },
    "disk": {
      "enabled": true,
      "show_all_drives": true
    },
    "network": {
      "enabled": true
    },
    "processes": {
      "enabled": true,
      "top_count": 10
    }
  },
  "ui": {
    "theme": "dark",
    "chart_style": "plotly",
    "show_system_info": true
  },
  "logging": {
    "enabled": true,
    "level": "INFO",
    "file": "data/logs/gamecore.log"
  }
}
